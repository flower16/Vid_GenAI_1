# Copy to frontend/.env.local. All optional: with no Azure vars the login screen
# runs in demo mode (the backend's local Admin principal). Set the Azure vars to
# enable the "Sign in with Azure AD (SSO)" button.

VITE_API_URL=http://localhost:8000

# --- Azure AD SSO (enables the SSO button when VITE_AZURE_CLIENT_ID is set) ---
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_REDIRECT_URI=http://localhost:5173
VITE_API_SCOPE=api://fdic-part370/.default
