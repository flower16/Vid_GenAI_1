# Copy to .env and fill in. Platform runs end-to-end locally even if blank
# (RAG falls back to in-code rules; persistence falls back to audit_log.jsonl).

ENVIRONMENT=local
LOG_LEVEL=INFO

# --- LLM (default to latest Claude) ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
OPENAI_API_KEY=            # used for embeddings (RAG)

# --- LangSmith ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fdic-part370
LANGSMITH_TRACING=false

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_INDEX=fdic-part370

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=FDIC_PART370
SNOWFLAKE_SCHEMA=CORE
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=

# --- Azure AD SSO ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_AUDIENCE=
